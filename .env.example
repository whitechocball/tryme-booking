# ==================== 數據庫配置 ====================
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ==================== 應用配置 ====================
PORT=3000
APP_URL=https://tryme-app-production.up.railway.app
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tryme2024

# ==================== 企業微信配置 ====================
# 企業 ID（在企業微信管理後台 → 我的企業 → 企業信息中查看）
WECHAT_CORP_ID=ww6ccfc2612e6f75fd

# 應用 AgentID（在企業微信管理後台 → 應用管理 → 應用中查看）
WECHAT_AGENT_ID=1000002

# 應用 Secret（在企業微信管理後台 → 應用管理 → 應用中查看）
WECHAT_SECRET=your_secret_here

# ==================== 企業微信回調配置 ====================
# 回調 Token（在企業微信管理後台 → 應用管理 → 應用 → 接收消息中設定）
WECHAT_CALLBACK_TOKEN=your_callback_token_here

# 回調 EncodingAESKey（在企業微信管理後台 → 應用管理 → 應用 → 接收消息中設定）
WECHAT_ENCODING_AES_KEY=your_encoding_aes_key_here

# ==================== 企業微信域名驗證 ====================
# 驗證文件名（如 WW_verify_xxxxxxxx.txt）
WECHAT_VERIFY_FILE_NAME=
# 驗證文件內容
WECHAT_VERIFY_FILE_CONTENT=

# ==================== Telegram Bot 配置 ====================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ==================== OpenAI 配置 ====================
OPENAI_API_KEY=your_openai_api_key_here
