<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tryme 管理後台 - 技師管理</title>
  <link rel="stylesheet" href="/admin-styles.css">
  <style>
    .vip-badge {
      display: inline-block;
      background: linear-gradient(135deg, #f59e0b, #d97706);
      color: white;
      padding: 2px 8px;
      border-radius: 10px;
      font-size: 11px;
      font-weight: 700;
    }
    .checkbox-group {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .checkbox-group input[type="checkbox"] {
      width: 16px;
      height: 16px;
    }
  </style>
</head>
<body>
  <button class="menu-toggle" onclick="toggleSidebar()">&#9776;</button>
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

  <div class="container">
    <div class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <h1>Tryme</h1>
        <span class="version-tag">v1.0 | 2026-03-15</span>
      </div>
      <nav>
        <ul>
          <li><a href="/admin"><span class="nav-icon">&#9632;</span> 儀表板</a></li>
          <li><a href="/admin/bookings"><span class="nav-icon">&#128197;</span> 預約管理</a></li>
          <li><a href="/admin/noshows"><span class="nav-icon">&#9888;</span> 爽約管理</a></li>
          <li><a href="/admin/locations"><span class="nav-icon">&#127968;</span> 場所管理</a></li>
          <li><a href="/admin/therapists" class="active"><span class="nav-icon">&#128100;</span> 技師管理</a></li>
          <li><a href="/admin/customers"><span class="nav-icon">&#128101;</span> 客戶管理</a></li>
        </ul>
      </nav>
    </div>

    <div class="main-content">
      <div class="page-header">
        <h1>技師管理</h1>
      </div>

      <div class="content-section" style="margin-bottom:24px;">
        <h2>新增技師</h2>
        <div id="message"></div>
        <form onsubmit="createTherapist(event)">
          <div class="form-group">
            <label>技師名稱</label>
            <input type="text" id="name" required placeholder="例如: 小美">
          </div>
          <div class="form-group">
            <label>號碼</label>
            <input type="text" id="display-number" placeholder="例如: 001">
          </div>
          <div class="form-group">
            <label>所屬場所</label>
            <select id="location-id" required>
              <option value="">選擇場所...</option>
            </select>
          </div>
          <div class="form-group">
            <label>微信外部聯繫人 ID</label>
            <input type="text" id="external-user-id" placeholder="external_userid">
          </div>
          <div class="form-group checkbox-group">
            <input type="checkbox" id="is-vip">
            <label for="is-vip" style="margin:0; font-weight:normal;">VIP 技師</label>
          </div>
          <button type="submit" class="btn">新增</button>
        </form>
      </div>

      <div class="content-section">
        <h2>技師列表</h2>
        <div class="table-wrapper">
          <div id="therapists-container" class="loading">加載中...</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    }

    async function loadLocations() {
      try {
        const response = await fetch('/api/locations');
        const locations = await response.json();
        const select = document.getElementById('location-id');
        for (const loc of locations) {
          const option = document.createElement('option');
          option.value = loc.id;
          option.textContent = loc.code + ' - ' + loc.name;
          select.appendChild(option);
        }
      } catch (e) {
        console.error('加載場所失敗:', e);
      }
    }

    async function loadTherapists() {
      try {
        const response = await fetch('/api/therapists');
        const therapists = await response.json();

        if (!therapists.length) {
          document.getElementById('therapists-container').innerHTML = '<div style="text-align:center; color:#9ca3af; padding:24px;">暫無技師</div>';
          return;
        }

        let html = '<table><thead><tr><th>名稱</th><th>號碼</th><th>場所</th><th>微信ID</th><th>VIP</th><th>操作</th></tr></thead><tbody>';
        for (const t of therapists) {
          const vip = t.is_vip ? '<span class="vip-badge">VIP</span>' : '-';
          const wechatDisplay = t.external_user_id || t.wechat_id || '-';
          html += '<tr>';
          html += '<td>' + t.name + '</td>';
          html += '<td>' + (t.display_number || '-') + '</td>';
          html += '<td>' + (t.location_name || '未知') + '</td>';
          html += '<td style="font-size:11px; max-width:120px; overflow:hidden; text-overflow:ellipsis;">' + wechatDisplay + '</td>';
          html += '<td>' + vip + '</td>';
          html += '<td style="white-space:nowrap;">';
          html += '<button class="btn btn-sm" onclick="editTherapist(' + t.id + ')">編輯</button> ';
          html += '<button class="btn btn-danger btn-sm" onclick="deleteTherapist(' + t.id + ')">刪除</button>';
          html += '</td></tr>';
        }
        html += '</tbody></table>';
        document.getElementById('therapists-container').innerHTML = html;
      } catch (e) {
        document.getElementById('therapists-container').innerHTML = '<div class="msg-error">加載失敗</div>';
      }
    }

    async function createTherapist(event) {
      event.preventDefault();
      const name = document.getElementById('name').value;
      const displayNumber = document.getElementById('display-number').value;
      const locationId = parseInt(document.getElementById('location-id').value, 10);
      const externalUserId = document.getElementById('external-user-id').value;
      const isVip = document.getElementById('is-vip').checked;

      try {
        const res = await fetch('/api/therapists', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, displayNumber, locationId, externalUserId, isVip }),
        });
        const result = await res.json();
        if (result.success) {
          showMessage('技師已新增', 'success');
          document.getElementById('name').value = '';
          document.getElementById('display-number').value = '';
          document.getElementById('location-id').value = '';
          document.getElementById('external-user-id').value = '';
          document.getElementById('is-vip').checked = false;
          loadTherapists();
        } else {
          showMessage(result.error || '新增失敗', 'error');
        }
      } catch (e) {
        showMessage('新增失敗: ' + e.message, 'error');
      }
    }

    async function editTherapist(id) {
      const name = prompt('輸入新的技師名稱:');
      if (name === null) return;
      try {
        const res = await fetch('/api/therapists/' + id, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name }),
        });
        const result = await res.json();
        if (result.success) { showMessage('技師已更新', 'success'); loadTherapists(); }
        else showMessage('更新失敗', 'error');
      } catch (e) { showMessage('更新失敗', 'error'); }
    }

    async function deleteTherapist(id) {
      if (!confirm('確定要刪除此技師嗎？')) return;
      try {
        const res = await fetch('/api/therapists/' + id, { method: 'DELETE' });
        const result = await res.json();
        if (result.success) { showMessage('技師已刪除', 'success'); loadTherapists(); }
        else showMessage('刪除失敗', 'error');
      } catch (e) { showMessage('刪除失敗', 'error'); }
    }

    function showMessage(msg, type) {
      const div = document.getElementById('message');
      div.className = type === 'success' ? 'msg-success' : 'msg-error';
      div.textContent = msg;
      setTimeout(() => { div.textContent = ''; div.className = ''; }, 3000);
    }

    loadLocations();
    loadTherapists();
  </script>
</body>
</html>
