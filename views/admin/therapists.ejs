<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tryme 管理後台 - 技師管理</title>
  <link rel="stylesheet" href="/admin-styles.css">
  <style>
    .vip-badge {
      display: inline-block;
      background: linear-gradient(135deg, #f59e0b, #d97706);
      color: white;
      padding: 2px 8px;
      border-radius: 10px;
      font-size: 11px;
      font-weight: 700;
    }
    .checkbox-group {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .checkbox-group input[type="checkbox"] {
      width: 16px;
      height: 16px;
    }
    .tabs {
      display: flex;
      gap: 8px;
      margin-bottom: 16px;
      border-bottom: 1px solid #e5e7eb;
    }
    .tab-button {
      padding: 8px 16px;
      background: none;
      border: none;
      cursor: pointer;
      border-bottom: 3px solid transparent;
      color: #6b7280;
      font-weight: 500;
    }
    .tab-button.active {
      color: #3b82f6;
      border-bottom-color: #3b82f6;
    }
    .tab-content {
      display: none;
    }
    .tab-content.active {
      display: block;
    }
    .history-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 12px;
    }
    .history-table th,
    .history-table td {
      padding: 8px;
      border: 1px solid #e5e7eb;
      text-align: left;
    }
    .history-table th {
      background: #f9fafb;
      font-weight: 600;
    }
  </style>
</head>
<body>
  <button class="menu-toggle" onclick="toggleSidebar()">&#9776;</button>
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

  <div class="container">
    <div class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <h1>Tryme</h1>
        <span class="version-tag">v1.0 | 2026-03-15</span>
      </div>
      <nav>
        <ul>
          <li><a href="/admin"><span class="nav-icon">&#9632;</span> 儀表板</a></li>
          <li><a href="/admin/bookings"><span class="nav-icon">&#128197;</span> 預約管理</a></li>
          <li><a href="/admin/noshows"><span class="nav-icon">&#9888;</span> 爽約管理</a></li>
          <li><a href="/admin/locations"><span class="nav-icon">&#127968;</span> 場所管理</a></li>
          <li><a href="/admin/therapists" class="active"><span class="nav-icon">&#128100;</span> 技師管理</a></li>
          <li><a href="/admin/customers"><span class="nav-icon">&#128101;</span> 客戶管理</a></li>
        </ul>
      </nav>
    </div>

    <div class="main-content">
      <div class="page-header">
        <h1>技師管理</h1>
      </div>

      <div class="content-section" style="margin-bottom:24px;">
        <h2 id="form-title">新增技師</h2>
        <div id="message"></div>
        <form onsubmit="createTherapist(event)">
          <div class="form-group">
            <label>技師名稱 *</label>
            <input type="text" id="name" required placeholder="例如: 小美">
          </div>
          <div class="form-group">
            <label>號碼（工號）</label>
            <input type="text" id="display-number" placeholder="例如: 001">
          </div>
          <div class="form-group">
            <label>現職場所 *</label>
            <select id="current-location-id" required>
              <option value="">選擇場所...</option>
            </select>
          </div>
          <div class="form-group">
            <label>主要聯繫微信ID</label>
            <input type="text" id="wechat-id-primary" placeholder="例如: zhangsan123">
          </div>
          <div class="form-group">
            <label>次要聯繫微信ID</label>
            <input type="text" id="wechat-id-secondary" placeholder="備用微信ID">
          </div>
          <div class="form-group">
            <label>技師電話號碼</label>
            <input type="tel" id="phone-number" placeholder="例如: 13800138000">
          </div>
          <div class="form-group">
            <label>Telegram ID</label>
            <input type="text" id="telegram-id" placeholder="例如: @username">
          </div>
          <div class="form-group">
            <label>技師照片</label>
            <input type="file" id="profile-pic" accept="image/*" onchange="previewImage(event)">
            <div id="pic-preview" style="margin-top:8px;"></div>
          </div>
          <div class="form-group">
            <label>上班時間</label>
            <input type="time" id="work-start-time">
          </div>
          <div class="form-group">
            <label>下班時間</label>
            <input type="time" id="work-end-time">
          </div>
          <div class="form-group checkbox-group">
            <input type="checkbox" id="is-vip">
            <label for="is-vip" style="margin:0; font-weight:normal;">VIP 技師</label>
          </div>
          <button type="submit" class="btn" id="submit-btn">新增</button>
          <button type="button" class="btn" id="cancel-btn" style="display:none;background:#6b7280;margin-left:8px;" onclick="cancelEdit()">取消編輯</button>
        </form>
      </div>

      <div class="content-section">
        <h2>技師列表</h2>
        <div id="therapists-container" class="loading">加載中...</div>
      </div>
    </div>
  </div>

  <script>
    let locations = [];
    let currentEditingTherapistId = null;

    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    }

    async function loadLocations() {
      try {
        const response = await fetch('/api/locations');
        locations = await response.json();
        const select = document.getElementById('current-location-id');
        select.innerHTML = '<option value="">選擇場所...</option>';
        locations.forEach(loc => {
          const option = document.createElement('option');
          option.value = loc.id;
          option.textContent = `${loc.name} (${loc.code || 'N/A'})`;
          select.appendChild(option);
        });
      } catch (error) {
        console.error('加載場所失敗:', error);
      }
    }

    async function loadTherapists() {
      try {
        const response = await fetch('/api/therapists');
        const therapists = await response.json();
        displayTherapists(therapists);
      } catch (error) {
        document.getElementById('therapists-container').innerHTML = `<p style="color:red;">加載失敗: ${error.message}</p>`;
      }
    }

    let currentProfilePicBase64 = null;

    function previewImage(event) {
      const file = event.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function(e) {
        currentProfilePicBase64 = e.target.result;
        document.getElementById('pic-preview').innerHTML = 
          `<img src="${e.target.result}" style="max-width:100px;max-height:100px;border-radius:8px;">`;
      };
      reader.readAsDataURL(file);
    }

    function displayTherapists(therapists) {
      if (!therapists || therapists.length === 0) {
        document.getElementById('therapists-container').innerHTML = '<p>暫無技師記錄</p>';
        return;
      }

      let html = '<div class="table-wrapper"><table class="data-table"><thead><tr>' +
        '<th>照片</th>' +
        '<th>名稱</th>' +
        '<th>號碼</th>' +
        '<th>現職場所</th>' +
        '<th>Telegram</th>' +
        '<th>主要微信ID</th>' +
        '<th>次要微信ID</th>' +
        '<th>電話</th>' +
        '<th>上班時間</th>' +
        '<th>下班時間</th>' +
        '<th>VIP</th>' +
        '<th>操作</th>' +
        '</tr></thead><tbody>';

      therapists.forEach(t => {
        const picHtml = t.profile_pic_url 
          ? `<img src="${t.profile_pic_url}" style="width:40px;height:40px;border-radius:50%;object-fit:cover;">` 
          : '-';
        html += `<tr>
          <td>${picHtml}</td>
          <td>${t.name || '-'}</td>
          <td>${t.display_number || '-'}</td>
          <td>${t.location_name || '-'}</td>
          <td>${t.telegram_id || '-'}</td>
          <td>${t.wechat_id_primary || '-'}</td>
          <td>${t.wechat_id_secondary || '-'}</td>
          <td>${t.phone_number || '-'}</td>
          <td>${t.work_start_time || '-'}</td>
          <td>${t.work_end_time || '-'}</td>
          <td>${t.is_vip ? '<span class="vip-badge">VIP</span>' : '-'}</td>
          <td>
            <button onclick="editTherapist(${t.id})" class="btn-small">編輯</button>
            <button onclick="viewHistory(${t.id})" class="btn-small">歷史</button>
            <button onclick="deleteTherapist(${t.id})" class="btn-small btn-danger">刪除</button>
          </td>
        </tr>`;
      });

      html += '</tbody></table></div>';
      document.getElementById('therapists-container').innerHTML = html;
    }

    async function createTherapist(e) {
      e.preventDefault();
      const data = {
        name: document.getElementById('name').value,
        currentLocationId: parseInt(document.getElementById('current-location-id').value),
        displayNumber: document.getElementById('display-number').value || null,
        wechatIdPrimary: document.getElementById('wechat-id-primary').value || null,
        wechatIdSecondary: document.getElementById('wechat-id-secondary').value || null,
        phoneNumber: document.getElementById('phone-number').value || null,
        telegramId: document.getElementById('telegram-id').value || null,
        workStartTime: document.getElementById('work-start-time').value || null,
        workEndTime: document.getElementById('work-end-time').value || null,
        isVip: document.getElementById('is-vip').checked
      };
      if (currentProfilePicBase64) {
        data.profilePicUrl = currentProfilePicBase64;
      }

      try {
        let url = '/api/therapists';
        let method = 'POST';
        let successMsg = '技師已創建';

        if (currentEditingTherapistId) {
          url = `/api/therapists/${currentEditingTherapistId}`;
          method = 'PUT';
          successMsg = '技師已更新';
        }

        const response = await fetch(url, {
          method: method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await response.json();
        if (response.ok) {
          document.getElementById('message').innerHTML = `<p style="color:green;">✓ ${successMsg}</p>`;
          document.querySelector('form').reset();
          currentProfilePicBase64 = null;
          document.getElementById('pic-preview').innerHTML = '';
          currentEditingTherapistId = null;
          document.getElementById('form-title').textContent = '新增技師';
          document.getElementById('submit-btn').textContent = '新增';
          document.getElementById('cancel-btn').style.display = 'none';
          loadTherapists();
        } else {
          document.getElementById('message').innerHTML = `<p style="color:red;">✗ ${result.error}</p>`;
        }
      } catch (error) {
        document.getElementById('message').innerHTML = `<p style="color:red;">✗ 操作失敗: ${error.message}</p>`;
      }
    }

    async function editTherapist(id) {
      const therapist = await fetch(`/api/therapists/${id}`).then(r => r.json());
      document.getElementById('name').value = therapist.name;
      document.getElementById('display-number').value = therapist.display_number || '';
      document.getElementById('current-location-id').value = therapist.current_location_id || '';
      document.getElementById('wechat-id-primary').value = therapist.wechat_id_primary || '';
      document.getElementById('wechat-id-secondary').value = therapist.wechat_id_secondary || '';
      document.getElementById('phone-number').value = therapist.phone_number || '';
      document.getElementById('telegram-id').value = therapist.telegram_id || '';
      document.getElementById('work-start-time').value = therapist.work_start_time || '';
      document.getElementById('work-end-time').value = therapist.work_end_time || '';
      document.getElementById('is-vip').checked = therapist.is_vip;
      if (therapist.profile_pic_url) {
        document.getElementById('pic-preview').innerHTML = 
          `<img src="${therapist.profile_pic_url}" style="max-width:100px;max-height:100px;border-radius:8px;">`;
      } else {
        document.getElementById('pic-preview').innerHTML = '';
      }
      currentProfilePicBase64 = null;
      currentEditingTherapistId = id;
      document.getElementById('form-title').textContent = '編輯技師';
      document.getElementById('submit-btn').textContent = '更新';
      document.getElementById('cancel-btn').style.display = 'inline-block';
      window.scrollTo(0, 0);
    }

    function cancelEdit() {
      currentEditingTherapistId = null;
      currentProfilePicBase64 = null;
      document.querySelector('form').reset();
      document.getElementById('pic-preview').innerHTML = '';
      document.getElementById('form-title').textContent = '新增技師';
      document.getElementById('submit-btn').textContent = '新增';
      document.getElementById('cancel-btn').style.display = 'none';
    }

    async function deleteTherapist(id) {
      if (!confirm('確定刪除此技師嗎？')) return;
      try {
        const response = await fetch(`/api/therapists/${id}`, { method: 'DELETE' });
        if (response.ok) {
          loadTherapists();
        }
      } catch (error) {
        alert('刪除失敗: ' + error.message);
      }
    }

    async function viewHistory(id) {
      try {
        const response = await fetch(`/api/therapists/${id}/history`);
        const history = await response.json();
        let html = '<h3>工作歷史</h3>';
        if (history.length === 0) {
          html += '<p>暫無工作歷史記錄</p>';
        } else {
          html += '<table class="history-table"><thead><tr>' +
            '<th>場所</th><th>工號</th><th>開始日期</th><th>結束日期</th><th>操作</th>' +
            '</tr></thead><tbody>';
          history.forEach(h => {
            html += `<tr>
              <td>${h.location_name || '-'}</td>
              <td>${h.display_number || '-'}</td>
              <td>${h.start_date || '-'}</td>
              <td>${h.end_date || '-'}</td>
              <td><button onclick="deleteHistory(${h.id})" class="btn-small btn-danger">刪除</button></td>
            </tr>`;
          });
          html += '</tbody></table>';
        }
        alert(html);
      } catch (error) {
        alert('加載歷史失敗: ' + error.message);
      }
    }

    async function deleteHistory(id) {
      if (!confirm('確定刪除此歷史記錄嗎？')) return;
      try {
        const response = await fetch(`/api/therapists/history/${id}`, { method: 'DELETE' });
        if (response.ok) {
          loadTherapists();
        }
      } catch (error) {
        alert('刪除失敗: ' + error.message);
      }
    }

    // 初始化
    loadLocations();
    loadTherapists();
  </script>
</body>
</html>
