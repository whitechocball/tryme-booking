<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tryme 管理後台 - 客戶管理</title>
  <link rel="stylesheet" href="/admin-styles.css">
</head>
<body>
  <button class="menu-toggle" onclick="toggleSidebar()">&#9776;</button>
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

  <div class="container">
    <div class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <h1>Tryme</h1>
        <span class="version-tag">v1.0 | 2026-03-15</span>
      </div>
      <nav>
        <ul>
          <li><a href="/admin"><span class="nav-icon">&#9632;</span> 儀表板</a></li>
          <li><a href="/admin/bookings"><span class="nav-icon">&#128197;</span> 預約管理</a></li>
          <li><a href="/admin/noshows"><span class="nav-icon">&#9888;</span> 爽約管理</a></li>
          <li><a href="/admin/locations"><span class="nav-icon">&#127968;</span> 場所管理</a></li>
          <li><a href="/admin/therapists"><span class="nav-icon">&#128100;</span> 技師管理</a></li>
          <li><a href="/admin/customers" class="active"><span class="nav-icon">&#128101;</span> 客戶管理</a></li>
          <li><a href="/admin/wechat-binding"><span class="nav-icon">&#128279;</span> 企業微信綁定</a></li>
        </ul>
      </nav>
    </div>

    <div class="main-content">
      <div class="page-header">
        <h1>客戶管理</h1>
      </div>

      <div class="filters">
        <input type="text" id="search-name" placeholder="搜索客戶名稱或 Telegram ID">
        <button class="btn" onclick="loadCustomers()">搜索</button>
      </div>

      <div class="content-section">
        <div id="message"></div>
        <div class="table-wrapper">
          <div id="customers-container" class="loading">加載中...</div>
        </div>
      </div>
    </div>
  </div>

  <!-- 客戶詳情 Modal -->
  <div class="modal-overlay" id="customerModal">
    <div class="modal">
      <h3>客戶詳情</h3>
      <div id="customer-detail"></div>
      <div class="modal-actions">
        <button class="btn btn-outline" onclick="closeModal()">關閉</button>
      </div>
    </div>
  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    }

    function closeModal() {
      document.getElementById('customerModal').classList.remove('show');
    }

    async function loadCustomers() {
      try {
        const response = await fetch('/api/customers');
        const customers = await response.json();

        const searchTerm = document.getElementById('search-name').value.toLowerCase();
        const filtered = searchTerm ? customers.filter(c =>
          (c.name && c.name.toLowerCase().includes(searchTerm)) ||
          (c.telegram_id && c.telegram_id.toString().includes(searchTerm))
        ) : customers;

        if (!filtered.length) {
          document.getElementById('customers-container').innerHTML = '<div style="text-align:center; color:#9ca3af; padding:24px;">暫無客戶</div>';
          return;
        }

        let html = '<table><thead><tr><th>Telegram ID</th><th>名稱</th><th>爽約次數</th><th>建立時間</th><th>操作</th></tr></thead><tbody>';
        for (const c of filtered) {
          const noShowStyle = c.no_show_count > 0 ? 'color:#ef4444; font-weight:700;' : '';
          html += '<tr>';
          html += '<td style="font-family:monospace;">' + (c.telegram_id || '-') + '</td>';
          html += '<td>' + (c.name || '-') + '</td>';
          html += '<td style="' + noShowStyle + '">' + (c.no_show_count || 0) + '</td>';
          html += '<td>' + (c.created_at ? new Date(c.created_at).toLocaleDateString('zh-Hant-TW') : '-') + '</td>';
          html += '<td><button class="btn btn-sm" onclick="viewCustomer(' + c.id + ')">詳情</button></td>';
          html += '</tr>';
        }
        html += '</tbody></table>';
        document.getElementById('customers-container').innerHTML = html;
      } catch (e) {
        document.getElementById('customers-container').innerHTML = '<div class="msg-error">加載失敗</div>';
      }
    }

    async function viewCustomer(id) {
      try {
        const response = await fetch('/api/customers/' + id);
        const customer = await response.json();

        let html = '<div style="margin-bottom:12px;">';
        html += '<p><strong>Telegram ID：</strong>' + (customer.telegram_id || '-') + '</p>';
        html += '<p><strong>名稱：</strong>' + (customer.name || '-') + '</p>';
        html += '<p><strong>爽約次數：</strong><span style="color:#ef4444; font-weight:700;">' + (customer.no_show_count || 0) + '</span></p>';
        html += '<p><strong>建立時間：</strong>' + (customer.created_at ? new Date(customer.created_at).toLocaleString('zh-Hant-TW') : '-') + '</p>';
        html += '</div>';

        if (customer.noShows && customer.noShows.length > 0) {
          html += '<h4 style="margin:12px 0 8px; font-size:14px;">爽約記錄</h4>';
          html += '<div class="table-wrapper"><table style="min-width:300px;"><thead><tr><th>日期</th><th>原因</th></tr></thead><tbody>';
          for (const ns of customer.noShows) {
            html += '<tr><td>' + (ns.no_show_date || '') + '</td><td>' + (ns.reason || '-') + '</td></tr>';
          }
          html += '</tbody></table></div>';
        }

        document.getElementById('customer-detail').innerHTML = html;
        document.getElementById('customerModal').classList.add('show');
      } catch (e) {
        alert('加載失敗');
      }
    }

    function showMessage(msg, type) {
      const div = document.getElementById('message');
      div.className = type === 'success' ? 'msg-success' : 'msg-error';
      div.textContent = msg;
      setTimeout(() => { div.textContent = ''; div.className = ''; }, 3000);
    }

    loadCustomers();
  </script>
</body>
</html>
