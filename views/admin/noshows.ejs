<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tryme 管理後台 - 爽約管理</title>
  <link rel="stylesheet" href="/admin-styles.css">
</head>
<body>
  <button class="menu-toggle" onclick="toggleSidebar()">&#9776;</button>
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

  <div class="container">
    <div class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <h1>Tryme</h1>
        <span class="version-tag">v1.0 | 2026-03-15</span>
      </div>
      <nav>
        <ul>
          <li><a href="/admin"><span class="nav-icon">&#9632;</span> 儀表板</a></li>
          <li><a href="/admin/bookings"><span class="nav-icon">&#128197;</span> 預約管理</a></li>
          <li><a href="/admin/noshows" class="active"><span class="nav-icon">&#9888;</span> 爽約管理</a></li>
          <li><a href="/admin/locations"><span class="nav-icon">&#127968;</span> 場所管理</a></li>
          <li><a href="/admin/therapists"><span class="nav-icon">&#128100;</span> 技師管理</a></li>
          <li><a href="/admin/customers"><span class="nav-icon">&#128101;</span> 客戶管理</a></li>
        </ul>
      </nav>
    </div>

    <div class="main-content">
      <div class="page-header">
        <h1>爽約管理</h1>
      </div>

      <div class="filters">
        <input type="date" id="filter-start-date">
        <span style="color:#6b7280;">至</span>
        <input type="date" id="filter-end-date">
        <button class="btn" onclick="loadNoShows()">搜索</button>
      </div>

      <div class="content-section">
        <div id="message"></div>
        <div class="table-wrapper">
          <div id="noshows-container" class="loading">加載中...</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    }

    async function loadNoShows() {
      try {
        const startDate = document.getElementById('filter-start-date').value;
        const endDate = document.getElementById('filter-end-date').value;

        let url = '/api/noshows';
        const params = new URLSearchParams();
        if (startDate) params.append('startDate', startDate);
        if (endDate) params.append('endDate', endDate);
        if (params.toString()) url += '?' + params.toString();

        const response = await fetch(url);
        const noShows = await response.json();

        if (!noShows.length) {
          document.getElementById('noshows-container').innerHTML = '<div style="text-align:center; color:#9ca3af; padding:24px;">暫無爽約記錄</div>';
          return;
        }

        let html = '<table><thead><tr><th>ID</th><th>客戶</th><th>技師</th><th>爽約日期</th><th>原因</th><th>報告者</th><th>操作</th></tr></thead><tbody>';

        for (const ns of noShows) {
          html += '<tr>';
          html += '<td>' + ns.id + '</td>';
          html += '<td>' + (ns.customer_name || '未知') + '</td>';
          html += '<td>' + (ns.therapist_name || '未知') + '</td>';
          html += '<td>' + (ns.no_show_date || '') + '</td>';
          html += '<td>' + (ns.reason || '-') + '</td>';
          html += '<td>' + (ns.reported_by || '') + '</td>';
          html += '<td><button class="btn btn-danger btn-sm" onclick="deleteNoShow(' + ns.id + ')">撤銷</button></td>';
          html += '</tr>';
        }

        html += '</tbody></table>';
        document.getElementById('noshows-container').innerHTML = html;
      } catch (error) {
        console.error('加載爽約記錄失敗:', error);
        document.getElementById('noshows-container').innerHTML = '<div class="msg-error">加載失敗</div>';
      }
    }

    async function deleteNoShow(noShowId) {
      if (!confirm('確定要撤銷此爽約記錄嗎？')) return;
      try {
        const response = await fetch('/api/noshows/' + noShowId, { method: 'DELETE' });
        const result = await response.json();
        if (result.success) {
          showMessage('爽約記錄已撤銷', 'success');
          loadNoShows();
        } else {
          showMessage('撤銷失敗', 'error');
        }
      } catch (error) {
        showMessage('撤銷失敗: ' + error.message, 'error');
      }
    }

    function showMessage(msg, type) {
      const div = document.getElementById('message');
      div.className = type === 'success' ? 'msg-success' : 'msg-error';
      div.textContent = msg;
      setTimeout(() => { div.textContent = ''; div.className = ''; }, 3000);
    }

    loadNoShows();
  </script>
</body>
</html>
