<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tryme 管理後台 - 儀表板</title>
  <link rel="stylesheet" href="/admin-styles.css">
</head>
<body>
  <button class="menu-toggle" onclick="toggleSidebar()">&#9776;</button>
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

  <div class="container">
    <div class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <h1>Tryme</h1>
        <span class="version-tag">v1.1 | 2026-03-16</span>
      </div>
      <nav>
        <ul>
          <li><a href="/admin" class="active"><span class="nav-icon">&#9632;</span> 儀表板</a></li>
          <li><a href="/admin/bookings"><span class="nav-icon">&#128197;</span> 預約管理</a></li>
          <li><a href="/admin/noshows"><span class="nav-icon">&#9888;</span> 爽約管理</a></li>
          <li><a href="/admin/locations"><span class="nav-icon">&#127968;</span> 場所管理</a></li>
          <li><a href="/admin/therapists"><span class="nav-icon">&#128100;</span> 技師管理</a></li>
          <li><a href="/admin/customers"><span class="nav-icon">&#128101;</span> 客戶管理</a></li>
          <li><a href="/admin/wechat-binding"><span class="nav-icon">&#128279;</span> 企業微信綁定</a></li>
        </ul>
      </nav>
    </div>

    <div class="main-content">
      <div class="page-header">
        <h1>儀表板</h1>
        <div class="header-time" id="current-time"></div>
      </div>

      <!-- 版本信息 -->
      <div class="content-section" style="margin-bottom:24px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px;">
        <div>
          <strong style="font-size:16px; color:#1a1a2e;">Tryme 預約管理系統</strong>
          <span style="background:#dbeafe; color:#1e40af; padding:2px 8px; border-radius:4px; font-size:11px; font-weight:600; margin-left:8px;">v1.1</span>
        </div>
        <div style="color:#6b7280; font-size:13px;">發佈日期：2026-03-16 | 新增：衝突檢測 & 狀態流程</div>
      </div>

      <!-- 統計卡片 -->
      <div class="stats-grid">
        <div class="stat-card">
          <h3>今日預約</h3>
          <div class="number" id="today-bookings">0</div>
        </div>
        <div class="stat-card">
          <h3>待確認</h3>
          <div class="number" id="waiting-therapist">0</div>
        </div>
        <div class="stat-card">
          <h3>已確認</h3>
          <div class="number" id="waiting-service">0</div>
        </div>
        <div class="stat-card">
          <h3>進行中</h3>
          <div class="number" id="in-progress">0</div>
        </div>
        <div class="stat-card">
          <h3>衝突預約</h3>
          <div class="number" id="conflicts" style="color:#dc2626;">0</div>
        </div>
        <div class="stat-card">
          <h3>爽約記錄</h3>
          <div class="number" id="total-noshows">0</div>
        </div>
      </div>

      <!-- 技師預約排名榜 -->
      <div class="content-section">
        <h2>技師預約排名榜</h2>
        <div class="ranking-tabs" id="ranking-tabs">
          <button class="btn btn-outline active" data-days="30" onclick="loadRanking(30, this)">30日</button>
          <button class="btn btn-outline" data-days="20" onclick="loadRanking(20, this)">20日</button>
          <button class="btn btn-outline" data-days="10" onclick="loadRanking(10, this)">10日</button>
          <button class="btn btn-outline" data-days="1" onclick="loadRanking(1, this)">過去24小時</button>
        </div>
        <div id="ranking-container" class="loading">加載中...</div>
      </div>

      <!-- 最近預約 -->
      <div class="content-section">
        <h2>最近預約</h2>
        <div class="table-wrapper">
          <div id="recent-bookings" class="loading">加載中...</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    }

    function updateTime() {
      const now = new Date();
      document.getElementById('current-time').textContent = now.toLocaleString('zh-Hant-TW');
    }
    updateTime();
    setInterval(updateTime, 1000);

    const STATUS_MAP = {
      'pending': '待確認',
      'confirmed': '技師已確認',
      'in_progress': '進行中',
      'completed': '已完成',
      'cancelled': '已取消',
      'no_show': '爽約',
      'waiting_therapist': '等待技師回覆',
      'waiting_service': '等待進入服務',
      'customer_no_show': '客戶爽約',
      'therapist_cancelled': '技師取消',
      'therapist_no_show': '技師爽約',
    };

    async function loadStats() {
      try {
        const today = new Date().toISOString().split('T')[0];
        const response = await fetch('/api/bookings/stats/daily?date=' + today);
        const stats = await response.json();
        document.getElementById('today-bookings').textContent = stats.totalBookings || 0;
        document.getElementById('waiting-therapist').textContent = stats.waitingTherapist || stats.pendingBookings || 0;
        document.getElementById('waiting-service').textContent = stats.waitingService || stats.confirmedBookings || 0;
        document.getElementById('in-progress').textContent = stats.inProgress || 0;
        document.getElementById('conflicts').textContent = stats.conflicts || 0;
      } catch (e) {
        console.error('加載統計失敗:', e);
      }
    }

    async function loadNoShowCount() {
      try {
        const response = await fetch('/api/noshows');
        const data = await response.json();
        document.getElementById('total-noshows').textContent = Array.isArray(data) ? data.length : 0;
      } catch (e) {
        console.error('加載爽約失敗:', e);
      }
    }

    async function loadRanking(days, btnEl) {
      document.querySelectorAll('#ranking-tabs .btn').forEach(b => b.classList.remove('active'));
      if (btnEl) btnEl.classList.add('active');

      const container = document.getElementById('ranking-container');
      container.innerHTML = '<div class="loading">加載中...</div>';

      try {
        const response = await fetch('/api/bookings/ranking?days=' + days);
        const ranking = await response.json();

        if (!ranking.length) {
          container.innerHTML = '<div style="text-align:center; color:#9ca3af; padding:24px;">暫無數據</div>';
          return;
        }

        let html = '<ul class="ranking-list">';
        ranking.forEach((item, idx) => {
          const rankClass = idx === 0 ? 'top-1' : idx === 1 ? 'top-2' : idx === 2 ? 'top-3' : 'normal';
          const locationInfo = item.location_name ? (item.location_code + ' ' + item.location_name) : '';
          html += '<li class="ranking-item">';
          html += '  <div class="ranking-rank ' + rankClass + '">' + (idx + 1) + '</div>';
          html += '  <div class="ranking-info">';
          html += '    <div class="ranking-name">' + item.therapist_name + '</div>';
          html += '    <div class="ranking-location">' + locationInfo + '</div>';
          html += '  </div>';
          html += '  <div style="text-align:right;">';
          html += '    <div class="ranking-count">' + item.booking_count + '</div>';
          html += '    <div class="ranking-count-label">預約</div>';
          html += '  </div>';
          html += '</li>';
        });
        html += '</ul>';
        container.innerHTML = html;
      } catch (e) {
        console.error('加載排名失敗:', e);
        container.innerHTML = '<div class="msg-error">加載失敗</div>';
      }
    }

    async function loadRecentBookings() {
      try {
        const response = await fetch('/api/bookings');
        const bookings = await response.json();
        const recent = bookings.slice(0, 10);

        if (!recent.length) {
          document.getElementById('recent-bookings').innerHTML = '<div style="text-align:center; color:#9ca3af; padding:24px;">暫無預約</div>';
          return;
        }

        let html = '<table><thead><tr>';
        html += '<th>預約ID</th><th>客戶</th><th>技師</th><th>日期</th><th>狀態</th>';
        html += '</tr></thead><tbody>';

        for (const b of recent) {
          const displayId = b.booking_code || b.id;
          const statusLabel = STATUS_MAP[b.status] || b.status;
          const statusClass = 'status-' + b.status;
          const conflictMark = b.has_conflict ? ' <span style="color:#dc2626; font-size:11px; font-weight:600;">[衝突]</span>' : '';

          html += '<tr' + (b.has_conflict ? ' style="background:#fef2f2;"' : '') + '>';
          html += '<td>' + displayId + conflictMark + '</td>';
          html += '<td>' + (b.customer_name || 'TG:' + (b.telegram_id || '未知')) + '</td>';
          html += '<td>' + (b.therapist_name || '未知') + '</td>';
          html += '<td>' + (b.booking_date || '') + '</td>';
          html += '<td><span class="status-badge ' + statusClass + '">' + statusLabel + '</span></td>';
          html += '</tr>';
        }

        html += '</tbody></table>';
        document.getElementById('recent-bookings').innerHTML = html;
      } catch (e) {
        console.error('加載預約失敗:', e);
        document.getElementById('recent-bookings').innerHTML = '<div class="msg-error">加載失敗</div>';
      }
    }

    // 初始化
    loadStats();
    loadNoShowCount();
    loadRanking(30, null);
    loadRecentBookings();

    setInterval(() => {
      loadStats();
      loadNoShowCount();
      loadRecentBookings();
    }, 30000);
  </script>
</body>
</html>
