<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tryme 管理後台 - 場所管理</title>
  <link rel="stylesheet" href="/admin-styles.css">
</head>
<body>
  <button class="menu-toggle" onclick="toggleSidebar()">&#9776;</button>
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

  <div class="container">
    <div class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <h1>Tryme</h1>
        <span class="version-tag">v1.0 | 2026-03-15</span>
      </div>
      <nav>
        <ul>
          <li><a href="/admin"><span class="nav-icon">&#9632;</span> 儀表板</a></li>
          <li><a href="/admin/bookings"><span class="nav-icon">&#128197;</span> 預約管理</a></li>
          <li><a href="/admin/noshows"><span class="nav-icon">&#9888;</span> 爽約管理</a></li>
          <li><a href="/admin/locations" class="active"><span class="nav-icon">&#127968;</span> 場所管理</a></li>
          <li><a href="/admin/therapists"><span class="nav-icon">&#128100;</span> 技師管理</a></li>
          <li><a href="/admin/customers"><span class="nav-icon">&#128101;</span> 客戶管理</a></li>
          <li><a href="/admin/wechat-binding"><span class="nav-icon">&#128279;</span> 企業微信綁定</a></li>
        </ul>
      </nav>
    </div>

    <div class="main-content">
      <div class="page-header">
        <h1>場所管理</h1>
      </div>

      <div class="content-section" style="margin-bottom:24px;">
        <h2>新增場所</h2>
        <div id="message"></div>
        <form onsubmit="createLocation(event)">
          <div class="form-row">
            <div class="form-group">
              <label>場所名稱 *</label>
              <input type="text" id="name" required placeholder="例如: 黃金海岸" onblur="generateCode()">
            </div>
            <div class="form-group">
              <label>場所代碼 *</label>
              <div style="display: flex; gap: 8px;">
                <input type="text" id="code" required placeholder="自動生成" readonly style="flex: 1;">
                <button type="button" class="btn" onclick="generateCode()" style="white-space: nowrap;">自動生成</button>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label>描述（內部備注）</label>
            <textarea id="description" placeholder="記錄場所的特色或缺點，僅供後台查看" style="resize:vertical; min-height:60px;"></textarea>
          </div>

          <div class="form-group">
            <label>地圖連結（高德地圖）</label>
            <input type="url" id="mapUrl" placeholder="https://www.amap.com/search?...">
          </div>

          <button type="submit" class="btn">新增場所</button>
        </form>
      </div>

      <div class="content-section">
        <h2>場所列表</h2>
        <div class="table-wrapper">
          <div id="locations-container" class="loading">加載中...</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    }

    async function generateCode() {
      const name = document.getElementById('name').value.trim();
      if (!name) {
        document.getElementById('code').value = '';
        return;
      }

      try {
        const response = await fetch('/api/locations/generate-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name })
        });
        const data = await response.json();
        if (data.code) {
          document.getElementById('code').value = data.code;
        }
      } catch (e) {
        console.error('生成代碼失敗', e);
      }
    }

    async function loadLocations() {
      try {
        const response = await fetch('/api/locations');
        const locations = await response.json();

        if (!locations.length) {
          document.getElementById('locations-container').innerHTML = '<div style="text-align:center; color:#9ca3af; padding:24px;">暫無場所</div>';
          return;
        }

        let html = '<table><thead><tr><th>代碼</th><th>名稱</th><th>描述</th><th>地圖連結</th><th>操作</th></tr></thead><tbody>';
        for (const loc of locations) {
          html += '<tr>';
          html += '<td><strong>' + loc.code + '</strong></td>';
          html += '<td>' + loc.name + '</td>';
          html += '<td>' + (loc.description ? loc.description.substring(0, 30) + (loc.description.length > 30 ? '...' : '') : '-') + '</td>';
          html += '<td>' + (loc.map_url ? '<a href="' + loc.map_url + '" target="_blank" style="color:#3b82f6;">查看地圖</a>' : '-') + '</td>';
          html += '<td style="white-space:nowrap;">';
          html += '<button class="btn btn-sm" onclick="editLocation(' + loc.id + ')">編輯</button> ';
          html += '<button class="btn btn-danger btn-sm" onclick="deleteLocation(' + loc.id + ')">刪除</button>';
          html += '</td></tr>';
        }
        html += '</tbody></table>';
        document.getElementById('locations-container').innerHTML = html;
      } catch (e) {
        document.getElementById('locations-container').innerHTML = '<div class="msg-error">加載失敗</div>';
      }
    }

    async function createLocation(event) {
      event.preventDefault();
      const code = document.getElementById('code').value.trim();
      const name = document.getElementById('name').value.trim();
      const description = document.getElementById('description').value.trim();
      const mapUrl = document.getElementById('mapUrl').value.trim();

      if (!code || !name) {
        showMessage('缺少必要欄位', 'error');
        return;
      }

      try {
        const response = await fetch('/api/locations', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code, name, description: description || null, mapUrl: mapUrl || null })
        });
        const data = await response.json();

        if (data.success) {
          showMessage('場所已創建', 'success');
          document.getElementById('code').value = '';
          document.getElementById('name').value = '';
          document.getElementById('description').value = '';
          document.getElementById('mapUrl').value = '';
          loadLocations();
        } else {
          showMessage(data.error || '創建失敗', 'error');
        }
      } catch (e) {
        showMessage('創建失敗: ' + e.message, 'error');
      }
    }

    async function editLocation(id) {
      const name = prompt('輸入新的場所名稱:');
      if (!name) return;

      try {
        const response = await fetch('/api/locations/' + id, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name })
        });
        const data = await response.json();

        if (data.success) {
          showMessage('場所已更新', 'success');
          loadLocations();
        } else {
          showMessage(data.error || '更新失敗', 'error');
        }
      } catch (e) {
        showMessage('更新失敗: ' + e.message, 'error');
      }
    }

    async function deleteLocation(id) {
      if (!confirm('確認刪除此場所？')) return;

      try {
        const response = await fetch('/api/locations/' + id, {
          method: 'DELETE'
        });
        const data = await response.json();

        if (data.success) {
          showMessage('場所已刪除', 'success');
          loadLocations();
        } else {
          showMessage(data.error || '刪除失敗', 'error');
        }
      } catch (e) {
        showMessage('刪除失敗: ' + e.message, 'error');
      }
    }

    function showMessage(msg, type) {
      const el = document.getElementById('message');
      el.className = 'msg-' + type;
      el.textContent = msg;
      setTimeout(() => { el.textContent = ''; el.className = ''; }, 3000);
    }

    loadLocations();
  </script>
</body>
</html>
