<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tryme 管理後台 - 預約管理</title>
  <link rel="stylesheet" href="/admin-styles.css">
  <style>
    .therapist-cell {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .therapist-info {
      flex: 1;
    }
    .therapist-pic-link {
      color: #3b82f6;
      text-decoration: none;
      font-size: 12px;
      cursor: pointer;
    }
    .therapist-pic-link:hover {
      text-decoration: underline;
    }
    .pic-modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.7);
      z-index: 1000;
      align-items: center;
      justify-content: center;
    }
    .pic-modal.show {
      display: flex;
    }
    .pic-modal-content {
      background: white;
      padding: 20px;
      border-radius: 8px;
      max-width: 90%;
      max-height: 90%;
      overflow: auto;
    }
    .pic-modal img {
      max-width: 100%;
      max-height: 600px;
    }
    .pic-modal-close {
      float: right;
      cursor: pointer;
      font-size: 24px;
      color: #999;
    }
  </style>
</head>
<body>
  <button class="menu-toggle" onclick="toggleSidebar()">&#9776;</button>
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

  <div class="container">
    <div class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <h1>Tryme</h1>
        <span class="version-tag">v1.0 | 2026-03-15</span>
      </div>
      <nav>
        <ul>
          <li><a href="/admin"><span class="nav-icon">&#9632;</span> 儀表板</a></li>
          <li><a href="/admin/bookings" class="active"><span class="nav-icon">&#128197;</span> 預約管理</a></li>
          <li><a href="/admin/noshows"><span class="nav-icon">&#9888;</span> 爽約管理</a></li>
          <li><a href="/admin/locations"><span class="nav-icon">&#127968;</span> 場所管理</a></li>
          <li><a href="/admin/therapists"><span class="nav-icon">&#128100;</span> 技師管理</a></li>
          <li><a href="/admin/customers"><span class="nav-icon">&#128101;</span> 客戶管理</a></li>
          <li><a href="/admin/wechat-binding"><span class="nav-icon">&#128279;</span> 企業微信綁定</a></li>
        </ul>
      </nav>
    </div>

    <div class="main-content">
      <div class="page-header">
        <h1>預約管理</h1>
      </div>

      <div class="filters">
        <input type="date" id="filter-date" placeholder="篩選日期">
        <select id="filter-status">
          <option value="">所有狀態</option>
          <option value="waiting_therapist">等待技師回覆</option>
          <option value="waiting_service">等待進入服務</option>
          <option value="completed">已完成服務</option>
          <option value="customer_no_show">客戶爽約</option>
          <option value="therapist_cancelled">技師取消</option>
          <option value="therapist_no_show">技師爽約</option>
        </select>
        <button class="btn" onclick="loadBookings()">搜索</button>
      </div>

      <div class="content-section">
        <div id="message"></div>
        <div class="table-wrapper">
          <div id="bookings-container" class="loading">加載中...</div>
        </div>
      </div>
    </div>
  </div>

  <!-- 圖片查看模態框 -->
  <div class="pic-modal" id="picModal">
    <div class="pic-modal-content">
      <span class="pic-modal-close" onclick="closePicModal()">&times;</span>
      <img id="picImage" src="" alt="技師頭像">
    </div>
  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    }

    const STATUS_MAP = {
      'waiting_therapist': '等待技師回覆',
      'waiting_service': '等待進入服務',
      'completed': '已完成服務',
      'customer_no_show': '客戶爽約',
      'therapist_cancelled': '技師取消',
      'therapist_no_show': '技師爽約',
      'pending': '待處理',
      'confirmed': '已確認',
      'rejected': '已拒絕',
      'cancelled': '已取消',
    };

    function showPicModal(picUrl) {
      if (!picUrl) {
        alert('暫無圖片');
        return;
      }
      document.getElementById('picImage').src = picUrl;
      document.getElementById('picModal').classList.add('show');
    }

    function closePicModal() {
      document.getElementById('picModal').classList.remove('show');
    }

    async function loadBookings() {
      try {
        const date = document.getElementById('filter-date').value;
        const status = document.getElementById('filter-status').value;

        let url = '/api/bookings';
        const params = new URLSearchParams();
        if (date) params.append('bookingDate', date);
        if (status) params.append('status', status);
        if (params.toString()) url += '?' + params.toString();

        const response = await fetch(url);
        const bookings = await response.json();

        if (!bookings.length) {
          document.getElementById('bookings-container').innerHTML = '<div style="text-align:center; color:#9ca3af; padding:24px;">暫無預約記錄</div>';
          return;
        }

        let html = '<table><thead><tr>';
        html += '<th>預約ID</th><th>客戶</th><th>技師</th><th>工號</th><th>日期</th><th>客戶預約時段</th><th>工作時間</th><th>狀態</th>';
        html += '</tr></thead><tbody>';

        for (const b of bookings) {
          const displayId = b.booking_code || b.id;
          const statusLabel = STATUS_MAP[b.status] || b.status;
          const statusClass = 'status-' + b.status;
          const customerDisplay = b.customer_name || ('TG:' + (b.telegram_id || '未知'));
          
          // 技師欄位：顯示技師名稱、微信ID和圖片連結
          let therapistDisplay = b.therapist_name || '未知';
          if (b.wechat_id) {
            therapistDisplay += '<br><small style="color:#6b7280;">微信: ' + b.wechat_id + '</small>';
          }
          if (b.profile_pic_url) {
            therapistDisplay += ' <a href="#" class="therapist-pic-link" onclick="showPicModal(\'' + b.profile_pic_url.replace(/'/g, "\\'") + '\'); return false;">(pic)</a>';
          }
          
          // 工號欄位
          const workNumber = b.display_number || '-';
          
          // 工作時間
          const workTime = (b.work_start_time && b.work_end_time) 
            ? (b.work_start_time.substring(0, 5) + ' - ' + b.work_end_time.substring(0, 5))
            : '-';
          
          // 客戶預約時段
          const timeDisplay = (b.time_slot || '') + ' ' + (b.time_option || '');

          html += '<tr>';
          html += '<td style="font-family:monospace; font-size:12px;">' + displayId + '</td>';
          html += '<td>' + customerDisplay + '</td>';
          html += '<td>' + therapistDisplay + '</td>';
          html += '<td style="text-align:center;">' + workNumber + '</td>';
          html += '<td>' + (b.booking_date || '') + '</td>';
          html += '<td>' + timeDisplay + '</td>';
          html += '<td>' + workTime + '</td>';
          html += '<td><span class="status-badge ' + statusClass + '">' + statusLabel + '</span></td>';
          html += '</tr>';
        }

        html += '</tbody></table>';
        document.getElementById('bookings-container').innerHTML = html;
      } catch (error) {
        console.error('加載預約失敗:', error);
        document.getElementById('bookings-container').innerHTML = '<div class="msg-error">加載失敗</div>';
      }
    }

    function showMessage(message, type) {
      const div = document.getElementById('message');
      div.className = type === 'success' ? 'msg-success' : 'msg-error';
      div.textContent = message;
      setTimeout(() => { div.textContent = ''; div.className = ''; }, 3000);
    }

    loadBookings();
  </script>
</body>
</html>
