<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>預約管理 - Tryme Admin</title>
  <link rel="stylesheet" href="/admin-styles.css">
  <style>
    /* 操作按鈕 */
    .action-btns { display: flex; gap: 4px; flex-wrap: wrap; }
    .btn-xs { padding: 3px 8px; font-size: 11px; border: none; border-radius: 4px; cursor: pointer; font-weight: 500; white-space: nowrap; }
    .btn-confirm { background: #10b981; color: white; }
    .btn-start { background: #3b82f6; color: white; }
    .btn-complete { background: #8b5cf6; color: white; }
    .btn-cancel-action { background: #ef4444; color: white; }
    .btn-noshow { background: #f59e0b; color: white; }
    .conflict-row { background: #fef2f2 !important; }
    .conflict-badge { display: inline-block; background: #ef4444; color: white; font-size: 10px; padding: 1px 5px; border-radius: 3px; margin-left: 4px; }
    .timeout-badge { display: inline-block; background: #f59e0b; color: white; font-size: 10px; padding: 1px 5px; border-radius: 3px; margin-left: 4px; }

    /* 統一狀態 badge 樣式 */
    .status-pending { background: #fef3c7; color: #92400e; }
    .status-confirmed { background: #dbeafe; color: #1e40af; }
    .status-in_progress { background: #e0e7ff; color: #3730a3; }
    .status-completed { background: #d1fae5; color: #065f46; }
    .status-cancelled { background: #e5e7eb; color: #374151; }
    .status-no_show { background: #fee2e2; color: #991b1b; }
    .status-rescheduled { background: #fce7f3; color: #9d174d; }

    /* 模態框 */
    .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 2000; justify-content: center; align-items: center; }
    .modal-overlay.show { display: flex; }
    .modal-content { background: white; border-radius: 12px; padding: 24px; max-width: 400px; width: 90%; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
    .modal-content h3 { margin: 0 0 16px; font-size: 16px; }
    .modal-content .form-group { margin-bottom: 12px; }
    .modal-content label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 4px; }
    .modal-content select, .modal-content textarea { width: 100%; padding: 8px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 13px; }
    .modal-actions { display: flex; gap: 8px; margin-top: 16px; }
    .modal-actions button { flex: 1; padding: 8px; border: none; border-radius: 6px; cursor: pointer; font-size: 13px; font-weight: 500; }
    .modal-actions .btn-primary { background: #3b82f6; color: white; }
    .modal-actions .btn-secondary { background: #e5e7eb; color: #374151; }
  </style>
</head>
<body>
  <div class="container">
    <!-- 側邊欄 -->
    <button class="menu-toggle" onclick="document.querySelector('.sidebar').classList.toggle('open')">☰</button>
    <div class="sidebar-overlay" onclick="document.querySelector('.sidebar').classList.remove('open')"></div>
    <aside class="sidebar">
      <div class="sidebar-header">
        <h1>TRYME</h1>
        <span class="version-tag">v2.0.0</span>
      </div>
      <nav>
        <ul>
          <li><a href="/admin"><span class="nav-icon">📊</span> 儀表板</a></li>
          <li><a href="/admin/bookings" class="active"><span class="nav-icon">📅</span> 預約管理</a></li>
          <li><a href="/admin/therapists"><span class="nav-icon">👩‍⚕️</span> 技師管理</a></li>
          <li><a href="/admin/locations"><span class="nav-icon">📍</span> 場所管理</a></li>
          <li><a href="/admin/customers"><span class="nav-icon">👥</span> 客戶管理</a></li>
          <li><a href="/admin/noshows"><span class="nav-icon">⚠️</span> 爽約記錄</a></li>
          <li><a href="/admin/wechat-binding"><span class="nav-icon">💬</span> 微信綁定</a></li>
        </ul>
      </nav>
    </aside>

    <!-- 主內容 -->
    <main class="main-content">
      <div class="page-header">
        <h1>預約管理</h1>
        <span class="header-time" id="current-time"></span>
      </div>

      <!-- 統計卡片 -->
      <div class="stats-grid">
        <div class="stat-card"><h3>總預約</h3><div class="number" id="stat-total">0</div></div>
        <div class="stat-card"><h3>待確認</h3><div class="number" id="stat-pending">0</div></div>
        <div class="stat-card"><h3>已確認</h3><div class="number" id="stat-confirmed">0</div></div>
        <div class="stat-card"><h3>進行中</h3><div class="number" id="stat-inprogress">0</div></div>
        <div class="stat-card"><h3>已完成</h3><div class="number" id="stat-completed">0</div></div>
        <div class="stat-card"><h3>衝突</h3><div class="number" id="stat-conflicts" style="color:#ef4444">0</div></div>
      </div>

      <!-- 篩選器 -->
      <div class="filters">
        <input type="date" id="filter-date" onchange="loadBookings()">
        <select id="filter-status" onchange="loadBookings()">
          <option value="">全部狀態</option>
          <option value="pending">待確認</option>
          <option value="confirmed">已確認</option>
          <option value="in_progress">進行中</option>
          <option value="completed">已完成</option>
          <option value="cancelled">已取消</option>
          <option value="no_show">爽約</option>
          <option value="rescheduled">改期待確認</option>
        </select>
        <select id="filter-therapist" onchange="loadBookings()">
          <option value="">全部技師</option>
        </select>
        <select id="filter-location" onchange="loadBookings()">
          <option value="">全部場所</option>
        </select>
        <label style="display:flex;align-items:center;gap:4px;font-size:13px;cursor:pointer;">
          <input type="checkbox" id="filter-conflict" onchange="loadBookings()"> 僅衝突
        </label>
        <button class="btn btn-sm" onclick="resetFilters()">重置</button>
        <button class="btn btn-sm btn-danger" onclick="detectConflicts()">衝突檢測</button>
        <button class="btn btn-sm" style="background:#f59e0b;color:white;" onclick="handleTimeouts()">超時處理</button>
      </div>

      <!-- 消息區 -->
      <div id="message"></div>

      <!-- 預約列表 -->
      <div class="content-section">
        <div class="table-wrapper" id="bookings-container">
          <div class="loading">載入中...</div>
        </div>
      </div>
    </main>
  </div>

  <!-- 狀態更改模態框 -->
  <div class="modal-overlay" id="statusModal">
    <div class="modal-content">
      <h3 id="modal-title">更改預約狀態</h3>
      <input type="hidden" id="modal-booking-id">
      <div class="form-group">
        <label>新狀態</label>
        <select id="modal-status">
          <option value="pending">待確認</option>
          <option value="confirmed">已確認</option>
          <option value="in_progress">進行中</option>
          <option value="completed">已完成</option>
          <option value="cancelled">已取消</option>
          <option value="no_show">爽約</option>
          <option value="rescheduled">改期待確認</option>
        </select>
      </div>
      <div class="form-group">
        <label>原因（選填）</label>
        <textarea id="modal-reason" rows="3" placeholder="輸入原因..."></textarea>
      </div>
      <div class="modal-actions">
        <button class="btn-secondary" onclick="closeStatusModal()">取消</button>
        <button class="btn-primary" onclick="submitStatusChange()">確認更改</button>
      </div>
    </div>
  </div>

  <script>
    // ========== 統一狀態映射（與後端 Booking.STATUS_LABELS 一致） ==========
    const STATUS_MAP = {
      'pending': '待確認',
      'confirmed': '技師已確認',
      'in_progress': '進行中',
      'completed': '已完成',
      'cancelled': '已取消',
      'no_show': '爽約',
      'rescheduled': '改期待確認',
    };

    const TIME_SLOT_MAP = {
      'morning': '早上',
      'afternoon': '中午',
      'evening': '晚上',
    };

    // 更新時間
    function updateTime() {
      const now = new Date();
      document.getElementById('current-time').textContent = now.toLocaleString('zh-TW');
    }
    updateTime();
    setInterval(updateTime, 1000);

    // 載入篩選選項
    async function loadFilterOptions() {
      try {
        const [therapistsRes, locationsRes] = await Promise.all([
          fetch('/api/therapists'),
          fetch('/api/locations'),
        ]);
        const therapists = await therapistsRes.json();
        const locations = await locationsRes.json();

        const therapistSelect = document.getElementById('filter-therapist');
        therapists.forEach(t => {
          const opt = document.createElement('option');
          opt.value = t.id;
          opt.textContent = (t.display_number || '') + ' ' + t.name;
          therapistSelect.appendChild(opt);
        });

        const locationSelect = document.getElementById('filter-location');
        locations.forEach(l => {
          const opt = document.createElement('option');
          opt.value = l.id;
          opt.textContent = (l.code || '') + ' ' + l.name;
          locationSelect.appendChild(opt);
        });
      } catch (e) {
        console.error('載入篩選選項失敗:', e);
      }
    }

    function resetFilters() {
      document.getElementById('filter-date').value = '';
      document.getElementById('filter-status').value = '';
      document.getElementById('filter-therapist').value = '';
      document.getElementById('filter-location').value = '';
      document.getElementById('filter-conflict').checked = false;
      loadBookings();
    }

    // 載入統計
    async function loadStats() {
      try {
        const date = document.getElementById('filter-date').value;
        const url = date ? `/api/bookings/stats/daily?date=${date}` : '/api/bookings/stats/daily';
        const res = await fetch(url);
        const stats = await res.json();
        document.getElementById('stat-total').textContent = stats.totalBookings || 0;
        document.getElementById('stat-pending').textContent = (stats.pending || 0) + (stats.rescheduled || 0);
        document.getElementById('stat-confirmed').textContent = stats.confirmed || 0;
        document.getElementById('stat-inprogress').textContent = stats.inProgress || 0;
        document.getElementById('stat-completed').textContent = stats.completed || 0;
        document.getElementById('stat-conflicts').textContent = stats.conflicts || 0;
      } catch (e) {
        console.error('載入統計失敗:', e);
      }
    }

    // 載入預約列表
    async function loadBookings() {
      try {
        const date = document.getElementById('filter-date').value;
        const status = document.getElementById('filter-status').value;
        const therapistId = document.getElementById('filter-therapist').value;
        const locationId = document.getElementById('filter-location').value;
        const hasConflict = document.getElementById('filter-conflict').checked;

        const params = new URLSearchParams();
        if (date) params.append('bookingDate', date);
        if (status) params.append('status', status);
        if (therapistId) params.append('therapistId', therapistId);
        if (locationId) params.append('locationId', locationId);
        if (hasConflict) params.append('hasConflict', 'true');

        let url = '/api/bookings';
        if (params.toString()) url += '?' + params.toString();

        const response = await fetch(url);
        const bookings = await response.json();

        if (!bookings.length) {
          document.getElementById('bookings-container').innerHTML = '<div style="text-align:center; color:#9ca3af; padding:24px;">暫無預約記錄</div>';
          loadStats();
          return;
        }

        let html = '<table><thead><tr>';
        html += '<th>ID</th><th>客戶</th><th>技師</th><th>場所</th><th>日期</th><th>時段</th><th>狀態</th><th>操作</th>';
        html += '</tr></thead><tbody>';

        for (const b of bookings) {
          const displayId = b.booking_code || b.id;
          const statusLabel = STATUS_MAP[b.status] || b.status;
          const statusClass = 'status-' + b.status;
          const customerDisplay = b.customer_name || ('TG:' + (b.telegram_id || '未知'));
          const therapistDisplay = b.therapist_name || '未知';
          const locationDisplay = b.location_name || '-';
          const timeDisplay = (TIME_SLOT_MAP[b.time_slot] || b.time_slot || '') + ' ' + (b.time_option || '');
          const isConflict = b.has_conflict;
          const isTimeout = b.timeout_notified;
          const rowClass = isConflict ? 'conflict-row' : '';

          html += '<tr class="' + rowClass + '">';
          html += '<td style="font-family:monospace; font-size:12px;">' + displayId;
          if (isConflict) html += '<span class="conflict-badge">衝突</span>';
          if (isTimeout) html += '<span class="timeout-badge">已超時</span>';
          html += '</td>';
          html += '<td>' + customerDisplay + '</td>';
          html += '<td>' + therapistDisplay + (b.display_number ? ' <small style="color:#6b7280;">#' + b.display_number + '</small>' : '') + '</td>';
          html += '<td>' + locationDisplay + '</td>';
          html += '<td>' + (b.booking_date || '') + '</td>';
          html += '<td>' + timeDisplay + '</td>';
          html += '<td><span class="status-badge ' + statusClass + '">' + statusLabel + '</span></td>';

          // 操作按鈕（使用統一狀態）
          html += '<td><div class="action-btns">';
          
          if (b.status === 'pending' || b.status === 'rescheduled') {
            html += '<button class="btn-xs btn-confirm" onclick="quickAction(' + b.id + ', \'confirm\')">確認</button>';
            html += '<button class="btn-xs btn-cancel-action" onclick="quickAction(' + b.id + ', \'cancel\')">取消</button>';
          }
          if (b.status === 'confirmed') {
            html += '<button class="btn-xs btn-start" onclick="quickAction(' + b.id + ', \'start\')">開始</button>';
            html += '<button class="btn-xs btn-cancel-action" onclick="quickAction(' + b.id + ', \'cancel\')">取消</button>';
          }
          if (b.status === 'in_progress') {
            html += '<button class="btn-xs btn-complete" onclick="quickAction(' + b.id + ', \'complete\')">完成</button>';
          }
          if (['pending', 'confirmed', 'in_progress', 'rescheduled'].includes(b.status)) {
            html += '<button class="btn-xs btn-noshow" onclick="quickAction(' + b.id + ', \'noshow\')">爽約</button>';
          }

          html += '<button class="btn-xs" style="background:#6b7280; color:white;" onclick="openStatusModal(' + b.id + ', \'' + b.status + '\')">改狀態</button>';

          html += '</div></td>';
          html += '</tr>';
        }

        html += '</tbody></table>';
        document.getElementById('bookings-container').innerHTML = html;
        loadStats();
      } catch (error) {
        console.error('加載預約失敗:', error);
        document.getElementById('bookings-container').innerHTML = '<div class="msg-error">加載失敗: ' + error.message + '</div>';
      }
    }

    // 快速操作
    async function quickAction(bookingId, action) {
      const actionMap = {
        'confirm': { url: `/api/bookings/${bookingId}/status`, body: { status: 'confirmed' }, label: '確認' },
        'start': { url: `/api/bookings/${bookingId}/start`, body: {}, label: '開始服務' },
        'complete': { url: `/api/bookings/${bookingId}/complete`, body: {}, label: '完成服務' },
        'cancel': { url: `/api/bookings/${bookingId}/status`, body: { status: 'cancelled', reason: '管理員取消' }, label: '取消' },
        'noshow': { url: `/api/bookings/${bookingId}/noshow`, body: { reason: '管理員標記爽約' }, label: '標記爽約' },
      };

      const config = actionMap[action];
      if (!config) return;

      if (!confirm(`確定要${config.label}預約 #${bookingId}？`)) return;

      try {
        const res = await fetch(config.url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(config.body),
        });
        const data = await res.json();
        if (res.ok) {
          showMessage(`${config.label}成功`, 'success');
          loadBookings();
        } else {
          showMessage(data.error || '操作失敗', 'error');
        }
      } catch (e) {
        showMessage('操作失敗: ' + e.message, 'error');
      }
    }

    // 狀態更改模態框
    function openStatusModal(bookingId, currentStatus) {
      document.getElementById('modal-booking-id').value = bookingId;
      document.getElementById('modal-status').value = currentStatus;
      document.getElementById('modal-reason').value = '';
      document.getElementById('modal-title').textContent = `更改預約 #${bookingId} 狀態`;
      document.getElementById('statusModal').classList.add('show');
    }

    function closeStatusModal() {
      document.getElementById('statusModal').classList.remove('show');
    }

    async function submitStatusChange() {
      const bookingId = document.getElementById('modal-booking-id').value;
      const status = document.getElementById('modal-status').value;
      const reason = document.getElementById('modal-reason').value;

      try {
        const res = await fetch(`/api/bookings/${bookingId}/status`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status, reason: reason || undefined }),
        });
        const data = await res.json();
        if (res.ok) {
          showMessage(`狀態已更新為 "${STATUS_MAP[status] || status}"`, 'success');
          closeStatusModal();
          loadBookings();
        } else {
          showMessage(data.error || '更新失敗', 'error');
        }
      } catch (e) {
        showMessage('更新失敗: ' + e.message, 'error');
      }
    }

    // 衝突檢測
    async function detectConflicts() {
      try {
        const res = await fetch('/api/bookings/detect-conflicts', { method: 'POST' });
        const data = await res.json();
        showMessage(data.message || '衝突檢測完成', 'success');
        loadBookings();
      } catch (e) {
        showMessage('衝突檢測失敗: ' + e.message, 'error');
      }
    }

    // 超時處理
    async function handleTimeouts() {
      try {
        const res = await fetch('/api/bookings/handle-timeouts', { method: 'POST' });
        const data = await res.json();
        showMessage(`超時處理完成：處理 ${data.processed || 0} 個，通知 ${data.notified || 0} 個`, 'success');
        loadBookings();
      } catch (e) {
        showMessage('超時處理失敗: ' + e.message, 'error');
      }
    }

    function showMessage(message, type) {
      const div = document.getElementById('message');
      div.className = type === 'success' ? 'msg-success' : 'msg-error';
      div.textContent = message;
      setTimeout(() => { div.textContent = ''; div.className = ''; }, 4000);
    }

    // 初始化
    loadFilterOptions();
    loadBookings();

    // 每 30 秒自動刷新
    setInterval(loadBookings, 30000);
  </script>
</body>
</html>
